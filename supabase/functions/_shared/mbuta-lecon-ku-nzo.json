      "reponse_correcte_mbuta": "Ni buna!",
      "reponse_correcte_subtitle": "Très bien !",
      "reponse_incorrecte_mbuta": "Kani... Vutu yela. Mbote.",
      "reponse_incorrecte_subtitle": "Essaie encore."
    },
    {
