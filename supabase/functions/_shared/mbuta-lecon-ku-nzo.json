{
  "lecon_id": "ku_nzo",
  "titre_mbuta": "Ku Nzo",
  "titre_subtitle": "À la maison",
  "sources": ["corpus Nzo Mikanda", "Ntu Kanda"],
  "ouverture": {
    "mbuta": "Mbote! Ku nzo we.",
    "subtitle": "Bonjour ! Tu es à la maison."
  },
  "echanges": [
    {
      "id": "N-01",
      "type": "qcm",
      "mbuta": "Bue ta kue bantu be mu nzo aku mu pari?",
