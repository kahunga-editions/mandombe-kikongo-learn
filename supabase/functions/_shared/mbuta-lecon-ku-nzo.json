        { "mbuta": "Zakala ni ta zakala.", "subtitle": "Je m'assieds.", "correct": true },
        { "mbuta": "Seka ni ta seka.", "subtitle": "Je dors.", "correct": false },
        { "mbuta": "Duka ni ta duka.", "subtitle": "Je sors.", "correct": false }
